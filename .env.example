# ─── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=123456:your-telegram-bot-token
ADMIN_ID=123456789

# ─── База данных ───────────────────────────────────────────────────────────────
# Render Postgres → Internal Database URL (postgresql+asyncpg://...)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/berkhelpermarket

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Render Redis → Internal Redis URL  |  Upstash → rediss://...
# ВАЖНО: не используйте localhost — только URL из переменных окружения хостинга
REDIS_URL=redis://your-redis-host:6379/0

# ─── ProxyAPI (OpenAI-compatible, работает из РФ) ──────────────────────────────
# Зарегистрируйтесь на https://proxyapi.ru и создайте API-ключ
PROXYAPI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PROXYAPI_BASE_URL=https://api.proxyapi.ru/openai/v1
AI_MODEL=gpt-4o-mini

# ─── ЮMoney ────────────────────────────────────────────────────────────────────
# Номер кошелька (найти в кабинете ЮMoney → профиль)
YOOMONEY_WALLET=410011XXXXXXXXX
# OAuth-токен: https://yoomoney.ru/docs/wallet/using-api/authorization/request
YOOMONEY_TOKEN=your-yoomoney-oauth-token
# Секрет HTTP-уведомлений: ЮMoney кабинет → Настройки → HTTP-уведомления
YOOMONEY_SECRET=your-yoomoney-notification-secret
# Ссылка для редиректа после оплаты (замените на username вашего бота)
PAYMENT_SUCCESS_URL=https://t.me/YourBotUsername

# ─── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MESSAGES=5
RATE_LIMIT_PERIOD_SECONDS=10

# ─── App / Render ──────────────────────────────────────────────────────────────
# Пустое значение → long-polling режим (локальная разработка)
# Для Render укажите публичный URL сервиса, например:
# WEBHOOK_BASE_URL=https://berkhelpermarket.onrender.com
WEBHOOK_BASE_URL=
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080
LOG_LEVEL=INFO
